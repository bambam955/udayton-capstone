# Flutter app commands — runs inside container or with local Flutter.
# The root justfile delegates here via Docker; you can also run directly.

set shell := ["bash", "-cu"]

# List available recipes
default:
    @just --list

# Start emulator on host (for connecting from Docker)
emulator:
    #!/usr/bin/env bash
    set -euo pipefail
    case "$(uname -s)" in
        Linux|Darwin)
            command -v flutter >/dev/null || echo "❌ Flutter not installed"
            avd=$(flutter emulators 2>/dev/null | grep '•' | grep -v '^Id' | head -1 | awk '{print $1}')
            if [ -z "$avd" ]; then
                echo "❌ No emulators found. Create one with: flutter emulators --create"
                exit 1
            fi
            echo "Launching $avd..."
            flutter emulators --launch "$avd"
            ;;
        MINGW*|MSYS*|CYGWIN*|Windows_NT)
            echo "Start emulator from Android Studio Device Manager"
            ;;
    esac

# Run tests
test app: (_in-app app "flutter test")

# Analyze code
check app: (_in-app app "flutter analyze")

# Format code
format app: (_in-app app "dart format .")

# Install dependencies
deps app: (_in-app app "flutter pub get")

# Clean build artifacts
clean app: (_in-app app "flutter clean")

# Build APK (e.g. just build main --release)
build app *args: (_in-app app "flutter build apk " + args)

# Run flutter doctor
doctor: (_in-app "main" "flutter doctor -v")

# Run command inside an app directory
[private]
_in-app app cmd:
    cd ./{{ app }} && {{ cmd }}
