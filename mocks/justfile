set shell := ["bash", "-cu"]

# List available recipes
default:
    @just --list

# Run mock endpoint contract smoke tests
test:
    npm run test

# Validate mock JSON files
check:
    npm run check

# Normalize mock JSON formatting
format:
    npm run format

# Install dependencies
deps:
    # Use install over clean-install to ensure package-lock.json can be updated.
    # This recipe will only ever be run in a development context.
    npm i --no-fund

clean:
    @echo "Nothing to do."

build:
    npm run build
