[sqlfluff]
dialect = postgres
templater = raw
max_line_length = 120
rules = core
# Increase max file size
large_file_skip_byte_limit = 50000
# The existing schema intentionally uses aligned column definitions, local
# indentation patterns, and dense seed rows. Keep SQLFluff focused on checks
# that do not rewrite the committed SQL style wholesale.
exclude_rules = LT01, LT02, LT05, LT08, CP02, CP03, CP05, AL03

[sqlfluff:indentation]
tab_space_size = 2
